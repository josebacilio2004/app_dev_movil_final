rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir acceso a roles específicos almacenados en el documento del usuario
    function hasRole(role) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == role;
    }

    // Helper: usuario autenticado
    function isAuth() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if !isAuth() || hasRole('admin');
      // Permitir crear perfil durante seeder (modo desarrollo)
      allow create: if true;
    }

    match /productos/{productId} {
      allow read: if isAuth();
      allow write: if hasRole('admin');
    }

    // CATÁLOGO DE PRODUCTOS — visible para admin, inversionista, comprador (NO operador)
    match /catalogo_productos/{productoId} {
      allow read: if !isAuth() || (isAuth() && (
        hasRole('admin') || 
        hasRole('inversionista') || 
        hasRole('comprador')
      ));
      allow write: if !isAuth() || hasRole('admin');
      // Permitir escritura durante seeder (modo desarrollo)
      allow create: if true;
    }

    match /pedidos/{pedidoId} {
      allow read: if isAuth() && (
        hasRole('admin') || 
        resource.data.inversionistaId == request.auth.uid || 
        resource.data.compradorId == request.auth.uid
      );
      allow write: if hasRole('admin') || (
        isAuth() && 
        hasRole('comprador') && 
        request.resource.data.compradorId == request.auth.uid
      );
    }

    match /pagos_capital/{pagoId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('comprador');
    }

    match /distribuidores/{distribuidorId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('inversionista');
    }

    match /tandas/{tandaId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('operador');
    }

    match /tanda_notas/{notaId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('operador');
    }

    match /compradores/{compradorId} {
      allow read: if isAuth();
      allow write: if hasRole('admin');
    }

    match /inversionistas/{inversionistaId} {
      allow read: if isAuth();
      allow write: if hasRole('admin');
    }

    match /facturas_comprador/{facturaId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('comprador');

      match /abonos/{abonoId} {
        allow read: if isAuth();
        allow write: if hasRole('admin') || hasRole('comprador');
      }
    }

    match /mayoristas_clientes/{clienteId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('comprador');
    }

    match /mayorista_stock/{stockId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('comprador');
    }

    match /mayorista_ventas/{ventaId} {
      allow read: if isAuth();
      allow write: if hasRole('admin') || hasRole('comprador');
    }
  }
}
