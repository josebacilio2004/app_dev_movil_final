rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper para obtener el rol del usuario en la colección /users de forma segura
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol
        : 'comprador';
    }

    // Regla para la colección de usuarios
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');
      allow delete: if isAuthenticated() && getUserRole() == 'admin';
    }

    // Reglas para el catálogo de productos
    match /catalogo_productos/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para movimientos de inventario (auditoría)
    match /inventario_movimientos/{movementId} {
      allow read: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'inversionista');
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para pedidos e inversiones (reforzado)
    match /pedidos/{pedidoId} {
      allow read: if isAuthenticated() && (
        resource.data.comprador_id == request.auth.uid || 
        getUserRole() == 'admin' || 
        getUserRole() == 'operador' || 
        getUserRole() == 'inversionista'
      );
      allow create: if isAuthenticated() && (
        request.resource.data.comprador_id == request.auth.uid ||
        getUserRole() == 'admin' ||
        getUserRole() == 'operador'
      );
      allow update, delete: if isAuthenticated() && (
        getUserRole() == 'admin' || 
        getUserRole() == 'operador'
      );
    }

    // Reglas para facturas y abonos
    match /facturas_comprador/{facturaId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
      
      match /abonos/{abonoId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Reglas para rutas de geolocalización
    match /geolocalizacion_rutas/{rutaId} {
      allow read, write: if isAuthenticated();
    }

    // Regla de lectura general para inversionistas y administradores en otras colecciones
    match /{document=**} {
      allow read, write: if isAuthenticated() && getUserRole() == 'admin';
      allow read: if isAuthenticated() && getUserRole() == 'inversionista';
    }
  }
}
