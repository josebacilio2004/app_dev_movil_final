rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper para obtener el rol del usuario de forma segura
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol
        : 'comprador';
    }

    // Reglas para la colección de usuarios
    match /users/{userId} {
      allow read, create: if true;
      allow update: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'admin');
      allow delete: if isAuthenticated() && getUserRole() == 'admin';
    }

    // Reglas para el catálogo de productos
    match /catalogo_productos/{productId} {
      allow read: if true;
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para movimientos de inventario (auditoría)
    match /inventario_movimientos/{movementId} {
      allow read: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'inversionista' || getUserRole() == 'operador');
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para pedidos e inversiones
    match /pedidos/{pedidoId} {
      allow read, create: if isAuthenticated();
      // Admin y operador pueden actualizar/eliminar cualquier pedido
      allow update, delete: if isAuthenticated() && (
        getUserRole() == 'admin' || 
        getUserRole() == 'operador'
      );
      // El comprador dueño del pedido puede actualizar solo los campos de tracking
      // (marcar como entregado al finalizar la simulación de delivery)
      allow update: if isAuthenticated() &&
        resource.data.comprador_id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['estado', 'tracking_enabled']);
    }

    // Reglas para facturas y abonos
    match /facturas_comprador/{facturaId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
      
      match /abonos/{abonoId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Reglas para rutas de geolocalización
    match /geolocalizacion_rutas/{rutaId} {
      allow read, write: if isAuthenticated();
    }

    // Reglas para distribuidores
    match /distribuidores/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para compradores
    match /compradores/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para inversionistas
    match /inversionistas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para tandas
    match /tandas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para notas de tanda
    match /tanda_notas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para mayoristas_clientes
    match /mayoristas_clientes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para mayorista_stock
    match /mayorista_stock/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para mayorista_ventas
    match /mayorista_ventas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'operador');
    }

    // Reglas para bitácora de mediciones AR (medidor láser)
    // Cada usuario solo accede a sus propios documentos; admin/operador puede leer todos
    match /mediciones_ar/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.usuario_id == request.auth.uid ||
        getUserRole() == 'admin' ||
        getUserRole() == 'operador'
      );
      allow create: if isAuthenticated() && request.resource.data.usuario_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        resource.data.usuario_id == request.auth.uid ||
        getUserRole() == 'admin'
      );
    }

    // Reglas para configuración general
    match /config/{documentId} {
      allow read: if true;
      allow write: if isAuthenticated() && (getUserRole() == 'admin');
    }
  }
}
